{
  "info": {
    "_postman_id": "a1b2c3d4-weatherflow-api",
    "name": "WeatherFlow API",
    "description": "API REST WeatherFlow (usuarios y estaciones). Ajustá la variable `baseUrl` si usás otro host/puerto (Sail suele ser 8100).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8100/api"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "stationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ada@example.com\",\n  \"name\": \"Ada\"\n}"
            },
            "url": "{{baseUrl}}/users",
            "description": "201 Created con el usuario en el body."
          },
          "response": []
        },
        {
          "name": "Get user",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "Pegá un `userId` en variables de colección o de entorno."
          },
          "response": []
        },
        {
          "name": "Update user",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo nombre\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "Podés enviar `name`, `email` o ambos."
          },
          "response": []
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "204 No Content."
          },
          "response": []
        },
        {
          "name": "Subscribe to station",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"station_id\": \"{{stationId}}\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/subscriptions",
            "description": "`station_id` es el id de la estación a la que se suscribe el usuario."
          },
          "response": []
        },
        {
          "name": "Unsubscribe from station",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/users/{{userId}}/subscriptions/{{stationId}}",
            "description": "El `stationId` en la URL es el id de la estación."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Stations",
      "item": [
        {
          "name": "Create station",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"owner_id\": \"{{userId}}\",\n  \"name\": \"Estación Central\",\n  \"latitude\": -34.6,\n  \"longitude\": -58.4,\n  \"sensor_model\": \"ACME-2000\",\n  \"status\": \"active\"\n}"
            },
            "url": "{{baseUrl}}/stations",
            "description": "`owner_id` debe ser un usuario existente. `status` opcional: active | inactive."
          },
          "response": []
        },
        {
          "name": "Get station",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/stations/{{stationId}}",
            "description": "Usá la variable `stationId`."
          },
          "response": []
        },
        {
          "name": "Update station",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo nombre\",\n  \"sensor_model\": \"ACME-3000\",\n  \"status\": \"inactive\"\n}"
            },
            "url": "{{baseUrl}}/stations/{{stationId}}",
            "description": "Si cambiás latitud/longitud, enviá ambas juntas."
          },
          "response": []
        },
        {
          "name": "Delete station",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/stations/{{stationId}}",
            "description": "204 No Content."
          },
          "response": []
        }
      ]
    }
  ]
}
