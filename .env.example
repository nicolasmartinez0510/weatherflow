APP_NAME=WeatherFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Laravel: base SQL para migraciones (users, cache, jobs, etc.). Por defecto SQLite en database/database.sqlite
DB_CONNECTION=sqlite

# WeatherFlow — persistencia de dominio (MongoDB). En Sail el host suele ser `mongodb`.
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=weatherflow

# Desarrollo local sin Redis ni colas asíncronas
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Tests: copiar a `.env.testing` y usar base `weatherflow-tests` + `WEATHERFLOW_TEST_USE_MONGO=true` si corres Feature contra Mongo (ver `tests/bootstrap.php`).

# --- Opcional: stack completo Sail (MySQL, Redis, Mailpit, etc.) ---
# Descomentá y ajustá según tu `docker-compose`; el proyecto no los requiere para la API WeatherFlow + Mongo.
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=sail
# DB_PASSWORD=password
# SESSION_DRIVER=database
# CACHE_STORE=database
# QUEUE_CONNECTION=database
# REDIS_HOST=redis
# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
